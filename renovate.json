{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "automerge": false,
  "semanticCommits": "enabled",
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchManagers": ["helm-values", "helmfile", "helmv3"],
      "enabled": true,
      "bumpVersion": "patch"
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "matchFileNames": ["charts/**", "charts/**/templates/hardcoded.yaml"],
      "bumpVersions": [
        {
          "filePatterns": ["{{packageFileDir}}/Chart.{yaml,yml}", "{{{replace '\/templates.*' '' packageFileDir}}}/Chart.{yaml,yml}"],
          "matchStrings": ["version:\\s(?<version>[^\\s]+)"],
          "bumpType": "{{#if isPatch}}patch{{else}}minor{{/if}}"
        }
      ]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "managerFilePatterns": ["/(^|/)Chart\\.yaml$/"],
      "matchStrings": [
        "#\\s?renovate: image=(?<depName>.*?)\\s?appVersion:\\s?\\'?(?<currentValue>[\\w+\\.\\-]*)'"
      ]
    },
    {
      "customType": "regex",
      "datasourceTemplate": "docker",
      "managerFilePatterns": ["/(^|/)templates/hardcoded\\.yaml$/"],
      "matchStrings": [
        "repository:\\s(?<depName>[\\w+\\/.\\-]*?)\\s+tag:\\s(?<currentValue>[\\w+\\.\\-]*)"
      ]
    }
  ]
}
